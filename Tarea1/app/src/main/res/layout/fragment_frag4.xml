<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="50dp"
    android:paddingHorizontal="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listas"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Las listas muestran colecciones de elementos y permiten al usuario interactuar con ellos."
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- ListView -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ListView: Lista vertical clásica."
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <ListView
            android:id="@+id/listViews"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:backgroundTint="@color/gray"
            android:background="@android:drawable/editbox_background"
            android:layout_marginTop="8dp"/>

        <!-- Spinner (lista desplegable) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spinner: Lista desplegable para seleccionar una opción."
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <Spinner
            android:id="@+id/spinnerr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ExpandableListView: Lista con grupos expandibles."
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <ExpandableListView
            android:id="@+id/expandableListVieww"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/gray"
            android:background="@android:drawable/editbox_background"/>
        <!-- RecyclerView -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RecyclerView: Lista moderna y eficiente, altamente personalizable."
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerVieww"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/gray"
            android:background="@android:drawable/editbox_background"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>


        <View android:layout_height="24dp" android:layout_width="match_parent"/>

    </LinearLayout>
</ScrollView>